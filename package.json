{
  "name": "sidnei-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "deps": "knip",
    "quality": "fallow",
    "verify": "npm run lint && npm run deps && npm run test && npm run build"
  },
  "dependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "fallow": "^2.89.0",
    "jsdom": "^27.0.0",
    "knip": "^5.64.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "vue-tsc": "^3.0.0"
  }
}
